generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  name        String?
  image       String?
  password    String?
  isActive    Boolean   @default(false)
  role        String    @default("USER")
  household   Household? @relation(fields: [householdId], references: [id])
  householdId Int?
  addedShoppingItems ShoppingListItem[]
  createdDevices Device[] @relation("DeviceCreatedBy")
  devicePairings DevicePairing[]
  apiTokens   ApiToken[]
  createdAt   DateTime  @default(now())
}

model VerificationToken {
  id         Int      @id @default(autoincrement())
  email      String
  token      String   @unique
  type       String
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
}

model Household {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  users     User[]
  locations Location[]
  stocks    Stock[]
  shoppingItems ShoppingListItem[]
  histories History[]
  devices   Device[]
  devicePairings DevicePairing[]
  apiTokens ApiToken[]
  scannerEvents ScannerEvent[]
  createdAt DateTime @default(now())
}

model Product {
  id        Int     @id @default(autoincrement())
  barcode   String  @unique
  name      String
  brand     String?
  image     String?
  createdAt DateTime @default(now())
  stocks    Stock[]
  shoppingItems ShoppingListItem[]
  histories History[]
  scannerEvents ScannerEvent[]
}

model Location {
  id        Int     @id @default(autoincrement())
  name      String
  household Household? @relation(fields: [householdId], references: [id])
  householdId Int?
  createdAt DateTime @default(now())
  stocks    Stock[]
  histories History[]
  defaultDevices Device[]
  scannerEvents ScannerEvent[]
}

model Stock {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  location   Location @relation(fields: [locationId], references: [id])
  locationId Int
  quantity   Float    @default(0)
  unit       String?
  mhd        DateTime?
  household  Household? @relation(fields: [householdId], references: [id])
  householdId Int?
  createdAt  DateTime @default(now())
}

model ShoppingListItem {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  household  Household @relation(fields: [householdId], references: [id])
  householdId Int
  quantity   Float    @default(1)
  note       String?
  unit       String?
  addedBy    User?    @relation(fields: [addedById], references: [id])
  addedById  Int?
  createdAt  DateTime @default(now())
}

model History {
  id         Int        @id @default(autoincrement())
  product    Product    @relation(fields: [productId], references: [id])
  productId  Int
  location   Location?  @relation(fields: [locationId], references: [id])
  locationId Int?
  quantity   Float
  action     String
  household  Household? @relation(fields: [householdId], references: [id])
  householdId Int?
  createdAt  DateTime   @default(now())
}

model Device {
  id                Int       @id @default(autoincrement())
  name              String
  type              String    @default("scanner")
  status            String    @default("active")
  household         Household @relation(fields: [householdId], references: [id])
  householdId       Int
  createdBy         User?     @relation("DeviceCreatedBy", fields: [createdById], references: [id])
  createdById       Int?
  defaultLocation   Location? @relation(fields: [defaultLocationId], references: [id])
  defaultLocationId Int?
  defaultMode       String    @default("lookup")
  lastSeenAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tokens            ApiToken[]
  pairings          DevicePairing[]
  scannerEvents     ScannerEvent[]

  @@index([householdId])
  @@index([status])
}

model ApiToken {
  id          Int       @id @default(autoincrement())
  name        String?
  tokenHash   String    @unique
  tokenPrefix String
  scopes      String
  clientType  String    @default("device")
  household   Household? @relation(fields: [householdId], references: [id])
  householdId Int?
  user        User?     @relation(fields: [userId], references: [id])
  userId      Int?
  device      Device?   @relation(fields: [deviceId], references: [id])
  deviceId    Int?
  scannerEvents ScannerEvent[]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([householdId])
  @@index([deviceId])
  @@index([revokedAt])
}

model DevicePairing {
  id                Int       @id @default(autoincrement())
  keyHash           String    @unique
  keyPrefix         String
  household         Household @relation(fields: [householdId], references: [id])
  householdId       Int
  createdBy         User?     @relation(fields: [createdById], references: [id])
  createdById       Int?
  device            Device?   @relation(fields: [deviceId], references: [id])
  deviceId          Int?
  deviceName        String?
  deviceType        String    @default("scanner")
  defaultLocationId Int?
  defaultMode       String    @default("lookup")
  scopes            String
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([householdId])
  @@index([expiresAt])
  @@index([usedAt])
}

model ScannerEvent {
  id          Int       @id @default(autoincrement())
  barcode     String
  mode        String    @default("lookup")
  source      String    @default("esp")
  status      String    @default("pending")
  note        String?
  rawPayload  String?
  household   Household @relation(fields: [householdId], references: [id])
  householdId Int
  device      Device?   @relation(fields: [deviceId], references: [id])
  deviceId    Int?
  apiToken    ApiToken? @relation(fields: [apiTokenId], references: [id])
  apiTokenId  Int?
  product     Product?  @relation(fields: [productId], references: [id])
  productId   Int?
  location    Location? @relation(fields: [locationId], references: [id])
  locationId  Int?
  quantity    Float?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([householdId, status])
  @@index([deviceId])
  @@index([barcode])
  @@index([createdAt])
}
