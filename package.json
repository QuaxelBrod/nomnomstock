{
  "name": "nomnomstock",
  "packageManager": "pnpm@8.8.0",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17 <24"
  },
  "workspaces": [
    "backend",
    "frontends/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel --filter nomnomstock-backend --filter nomnomstock-web run dev",
    "build:shared": "pnpm --filter nomnomstock-shared run build",
    "build:backend": "pnpm --filter nomnomstock-backend run build",
    "build:web": "pnpm --filter nomnomstock-web run build",
    "build": "pnpm run build:shared && pnpm run build:backend && pnpm run build:web",
    "typecheck": "pnpm --filter nomnomstock-shared run typecheck && pnpm --filter nomnomstock-backend run typecheck && pnpm --filter nomnomstock-web run typecheck",
    "start": "pnpm --filter nomnomstock-web run start",
    "start:backend": "pnpm --filter nomnomstock-backend run start",
    "lint": "pnpm --filter nomnomstock-web run lint",
    "format": "prettier --write .",
    "prisma:generate": "pnpm --filter nomnomstock-backend run prisma:generate",
    "prisma:migrate": "pnpm --filter nomnomstock-backend run prisma:migrate",
    "prisma:studio": "pnpm --filter nomnomstock-backend run prisma:studio",
    "prisma:seed": "pnpm --filter nomnomstock-backend run prisma:seed",
    "merge:products": "node scripts/merge_products.mjs",
    "smoke:flows": "node scripts/smoke_flows.mjs",
    "smoke:flows:web": "SMOKE_MODE=web node scripts/smoke_flows.mjs",
    "smoke:flows:backend": "SMOKE_MODE=backend node scripts/smoke_flows.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.5",
    "@prisma/client": "^5.0.0",
    "@zxing/library": "^0.18.6",
    "bcryptjs": "^2.4.3",
    "next": "^14.0.0",
    "next-auth": "^4.22.1",
    "nodemailer": "^7.0.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "postcss": "^8.4.0",
    "prettier": "^2.8.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.1.0"
  }
}
