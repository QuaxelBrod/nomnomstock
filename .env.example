# --- Core application URLs ---
# Public URL of the frontend (browser entrypoint)
APP_URL=http://localhost:3000
# NextAuth public URL (usually same as APP_URL)
NEXTAUTH_URL=http://localhost:3000

# --- Frontend -> Backend contract (split runtime) ---
# Internal backend base for frontend proxy/auth calls.
# Use container DNS name in Docker Compose, e.g. http://backend:3001
BACKEND_URL=http://localhost:3001
# Optional browser-visible fallback (normally same as BACKEND_URL).
NEXT_PUBLIC_API_BASE=http://localhost:3001
# Public API base embedded in scanner pairing QR payloads.
# Use the URL the ESP can reach, including /api/v1.
API_BASE_URL=http://localhost:3001/api/v1

# --- Base path deployment options ---
# Leave empty for root deployment.
BASE_PATH=
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Security/Auth ---
NEXTAUTH_SECRET=change_this_to_a_secure_random_value

# --- Database ---
# Absolute path is recommended in containers.
DATABASE_URL=file:/data/nomnom.db
# Backend-owned product/profile image storage.
UPLOAD_DIR=/data/uploads

# --- Admin / registration ---
SUPER_ADMIN_EMAIL=admin@example.com

# --- SMTP mail ---
SMTP_HOST=smtp.strato.de
SMTP_PORT=587
SMTP_USER=your@domain.tld
SMTP_PASS=your-smtp-password
EMAIL_FROM=your@domain.tld

# Set to false to skip real email sending in dev/tests.
EMAIL_AUTH_ENABLED=true

# --- Recipe generation / local LLM (optional) ---
# Generic OpenAI-compatible local server, e.g. llama.cpp llama-server.
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_MODEL=
LLM_ENABLED=true
LLM_TIMEOUT_MS=60000
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
# Optional if your local server requires a bearer token.
LLM_API_KEY=

# Legacy Ollama configuration. Use this instead of LLM_BASE_URL for Ollama.
OLLAMA_URL=
OLLAMA_MODEL=cortex
OLLAMA_ENABLED=true
