# App URL
APP_URL=http://localhost:3000

# NextAuth
NEXTAUTH_SECRET=change_this_to_a_secure_random_value

# Super admin (single email allowed)
SUPER_ADMIN_EMAIL=admin@example.com

# SMTP (Strato) - fill with your SMTP credentials
SMTP_HOST=smtp.strato.de
SMTP_PORT=587
SMTP_USER=your@domain.tld
SMTP_PASS=your-smtp-password
EMAIL_FROM=your@domain.tld

# Toggle email sending (set to 'false' for local/dev without internet)
EMAIL_AUTH_ENABLED=true

# Optional: for test installations without internet set to false to skip sending
# EMAIL_AUTH_ENABLED=false

# APP behaviour
# If set to 'true', new registrations require superadmin approval before activation
# To disable extra authorization (for tests), set EMAIL_AUTH_ENABLED=false above
