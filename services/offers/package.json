{
  "name": "nomnomstock-offers",
  "version": "0.1.0",
  "private": true,
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "typecheck": "pnpm run prisma:generate && tsc -p tsconfig.json --noEmit",
    "start": "node dist/src/server.js",
    "test:connector": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts",
    "test:browser": "ts-node-dev --transpile-only --exit-child scripts/test-browser-scrape.ts",
    "test:browser:marktkauf": "ts-node-dev --transpile-only --exit-child scripts/test-browser-scrape.ts marktkauf",
    "test:connector:aldi": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts aldi",
    "test:connector:cap": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts cap",
    "test:connector:edeka": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts edeka",
    "test:connector:kaufland": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts kaufland",
    "test:connector:lidl": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts lidl",
    "test:connector:marktkauf": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts marktkauf",
    "test:connector:netto": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts netto",
    "test:connector:norma": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts norma",
    "test:connector:rewe": "ts-node-dev --transpile-only --exit-child scripts/test-connector.ts rewe",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "playwright-core": "^1.61.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^18.19.0",
    "prisma": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.0"
  }
}
